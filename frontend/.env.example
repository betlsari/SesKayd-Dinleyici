# =====================================================================
# Keycloak SPA istemci (client) bilgileri
# ---------------------------------------------------------------------
# Bu değerleri öğrenmek için ADMİN KONSOLU YETKİSİNE ihtiyacın YOK.
# Keycloak'ı yöneten ekipten (genelde backend/.NET veya DevOps) şu üç
# bilgiyi iste:
#
#   1) Keycloak sunucu URL'si
#   2) Realm adı
#   3) Bu frontend uygulaması için tanımlanmış PUBLIC client id
#
# Kendi kullanıcı adın/şifren BURAYA YAZILMAZ. Giriş, Keycloak'ın kendi
# barındırdığı sayfaya yönlendirilerek yapılır (bkz. src/auth/AuthProvider.tsx).
#
# Kullanım: bu dosyayı ".env" olarak kopyala ve değerleri doldur.
#   cp .env.example .env
# =====================================================================

VITE_KEYCLOAK_URL=https://oauthtest.yasar.com.tr/auth
VITE_KEYCLOAK_REALM=VCARD
VITE_KEYCLOAK_CLIENT_ID=vcard-fe
